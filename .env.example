# Compose project namespace. Containers, volumes, and the default network
# all get prefixed with this — so the project is isolated from other
# Docker work on the same host.
COMPOSE_PROJECT_NAME=opensky

# Your host user's UID. Run `id -u` to find yours. Default 50000 matches
# the airflow user inside the official image; setting your own avoids
# permission issues on mounted volumes (logs, dags) on Linux hosts.
AIRFLOW_UID=1000

# --- Airflow secrets ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
# Generate with: openssl rand -base64 32
AIRFLOW_JWT_SECRET=
# Generate with: openssl rand -base64 32
AIRFLOW_SESSION_SECRET=

# --- Airflow metadata Postgres (internal only) ---
# Not exposed externally, but env-driven for consistency with the other
# services. Compose will refuse to start if the password is unset.
AIRFLOW_PG_USER=airflow
AIRFLOW_PG_PASSWORD=

# --- OpenSky API ---
# Register at https://opensky-network.org → Account → API Client
# Anonymous mode works (leave blank) but is rate-limited to ~100 calls/day.
# Authenticated mode gets 4000 calls/day.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- MinIO (S3-compatible local object store) ---
# Minimum 8 characters for password (MinIO enforces this).
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=opensky

# --- Analytics Postgres ---
# Host/port/db default to internal Docker network values; only change if
# you're running Postgres elsewhere.
ANALYTICS_PG_HOST=postgres-analytics
ANALYTICS_PG_PORT=5432
ANALYTICS_PG_DB=analytics
ANALYTICS_PG_USER=
ANALYTICS_PG_PASSWORD=

# --- Superset ---
SUPERSET_PG_USER=
SUPERSET_PG_PASSWORD=
# Generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_FIRST_NAME=Admin
SUPERSET_ADMIN_LAST_NAME=User
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=

# --- Mapbox ---
# Optional. Provides the basemap tiles for deck.gl map charts. Without it,
# points still render but on a black background.
# Create a *public* token (pk.*) at https://account.mapbox.com/access-tokens/
# with default scopes. Restrict it to http://localhost:38088 — Mapbox
# rejects IP literals (no 127.0.0.1) and path wildcards (no trailing /*).
# Access the dashboard via http://localhost:38088, not the IP, or basemaps
# silently fail.
MAPBOX_API_KEY=
