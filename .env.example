# Compose project namespace. Containers, volumes, and the default network
# all get prefixed with this — so the project is isolated from other
# Docker work on the same host.
COMPOSE_PROJECT_NAME=sancha1090

# Your host user's UID. Run `id -u` to find yours. Default 50000 matches
# the airflow user inside the official image; setting your own avoids
# permission issues on mounted volumes (logs, dags) on Linux hosts.
AIRFLOW_UID=1000

# Optional: layer a gitignored docker-compose.local.yml for host-specific tweaks
# (e.g. exposing a service port on the LAN). When set, Compose loads ONLY the
# files listed here, so include the base + override too. Leave unset otherwise.
# COMPOSE_FILE=docker-compose.yml:docker-compose.override.yml:docker-compose.local.yml

# --- Airflow secrets ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
# Generate with: openssl rand -base64 32
AIRFLOW_JWT_SECRET=
# Generate with: openssl rand -base64 32
AIRFLOW_SESSION_SECRET=

# --- Airflow metadata Postgres (internal only) ---
# Not exposed externally, but env-driven for consistency with the other
# services. Compose will refuse to start if the password is unset.
AIRFLOW_PG_USER=airflow
AIRFLOW_PG_PASSWORD=

# --- OpenSky API ---
# Register at https://opensky-network.org → Account → API Client
# Anonymous mode works (leave blank) but is rate-limited to ~100 calls/day.
# Authenticated mode gets 4000 calls/day.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Garage (S3-compatible local object store) ---
# Pre-generate the access/secret keys with: openssl rand -hex 32
S3_ENDPOINT=garage:3900
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=sancha1090

# Garage's own cluster secrets are not env vars: copy config/garage.toml.example
# to config/garage.toml and fill its three secret fields (compose bind-mounts that file).
#
# ClickHouse reads Garage via these same S3_* values — no new secret. Compose passes them
# to the clickhouse service as CH_S3_ACCESS_KEY / CH_S3_SECRET_KEY, which the Garage named
# collection (clickhouse/config.d/named_collection_garage.xml) reads via from_env so creds
# never appear inline in any s3() call.

# --- ClickHouse batch warehouse (P2 bronze dual-write) ---
# The Airflow tasks write to the in-network clickhouse service; these defaults already work
# (default user is open within the stack with no password). Only set to override.
# CLICKHOUSE_HOST=clickhouse
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DB=bronze
#
# P5 Superset cutover: the read-only CH user Superset connects as (clickhouse-connect). The compose
# clickhouse service reads CH_SUPERSET_PASSWORD via from_env (clickhouse/users.d/superset_ro.xml); the
# superset service substitutes it into clickhouse.yaml's URI (bootstrap.sh URL-encodes it). The username
# is fixed as superset_ro in docker-compose + the users.d XML, so only the password is set here.
CH_SUPERSET_PASSWORD=

# --- Analytics Postgres ---
# Host/port/db default to internal Docker network values; only change if
# you're running Postgres elsewhere.
ANALYTICS_PG_HOST=postgres-analytics
ANALYTICS_PG_PORT=5432
ANALYTICS_PG_DB=analytics
ANALYTICS_PG_USER=
ANALYTICS_PG_PASSWORD=

# --- Superset ---
SUPERSET_PG_USER=
SUPERSET_PG_PASSWORD=
# Generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_FIRST_NAME=Admin
SUPERSET_ADMIN_LAST_NAME=User
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=

# --- VPS failover collector (optional) ---
# Used by scripts/vps_up.sh + dags/sync_vps_states_buffer.py. Spin a Hetzner CX23
# while the local stack is down; collected parquets land in Cloudflare R2 and
# get pulled back into Garage when local resumes.
# R2: create a bucket scoped API token at https://dash.cloudflare.com → R2 → Manage API Tokens.
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET=
R2_BUCKET=opensky-vps-buffer
# Hetzner: hcloud CLI authenticates via HCLOUD_TOKEN or ~/.config/hcloud/cli.toml.
# SSH_KEY is optional; set to a key name registered in your Hetzner project to enable hcloud server ssh.
HCLOUD_TOKEN=
SSH_KEY=

# --- Redpanda (v4 ADS-B live hot path) ---
# Single-node Kafka broker for the live ADS-B feed; the rooftop antenna edge unit
# publishes readsb state to topic `adsb.live` over the LAN. REDPANDA_EXTERNAL_HOST
# is the address Redpanda *advertises* on its external listener — set it to the
# main PC's LAN IP (or a hostname the edge resolves). If left as `localhost`, the
# edge connects to the broker but is then handed back an unreachable address and
# can't produce. The LAN host port 19092 is NOT published by default — to expose it
# for the edge, add a `redpanda` ports block to the gitignored docker-compose.local.yml
# and list that file in COMPOSE_FILE above (snippet in README "Live hot path"; same
# pattern as Garage's :3900). In-stack consumers use the internal listener
# (redpanda:9092) and ignore this.
REDPANDA_EXTERNAL_HOST=localhost

# --- Mapbox ---
# Optional. Provides the basemap tiles for deck.gl map charts. Without it,
# points still render but on a black background.
# Create a *public* token (pk.*) at https://account.mapbox.com/access-tokens/
# with default scopes. Restrict it to http://localhost:38088 — Mapbox
# rejects IP literals (no 127.0.0.1) and path wildcards (no trailing /*).
# Access the dashboard via http://localhost:38088, not the IP, or basemaps
# silently fail.
MAPBOX_API_KEY=

# livemap receiver location for the range-outline render.
# SECRET: the real antenna is a home rooftop — put the exact coords in your gitignored .env,
# never here. This example is Carrot Tower (the public Sangenjaya landmark) and is also the
# code default, so the public showcase never carries the real location.
LIVEMAP_FEEDER_LAT=35.6434
LIVEMAP_FEEDER_LON=139.6692

# --- Cold archive (v6.4 NAS tiering, archive_raw_to_nas DAG) ---
# Tiers aged, already-ClickHoused raw Parquet from Garage to an NFS cold share (copy + verify, never deletes
# the Garage source). All optional — these are the code defaults. The NFS mount itself is host-specific, so add
# a `nas-cold` volume + an `airflow-scheduler` `/cold` mount to the gitignored docker-compose.local.yml (NEVER on
# clickhouse — NFS for CH active data corrupts), same pattern as Garage's :3900 / Redpanda's :19092 above.
# ARCHIVE_COLD_PATH=/cold              # in-container mount point the archiver writes to
# ARCHIVE_OLDER_THAN_DAYS=14           # only archive objects ClickHoused more than N days ago
# ARCHIVE_MAX_FILES=5000               # per-run cap (drains a backlog over successive daily runs)
# ARCHIVE_REQUIRE_MOUNT=1              # set on the prod scheduler: red the DAG if /cold isn't a live mount

# --- FAA SWIM / SCDS (swim-consumer service, always-on TFMData flight feed) ---
# Register a subscription at the SWIM SWIFT portal (https://swim.faa.gov) to get these.
# Real values are secrets — live only in the gitignored .env, never here.
SWIM_HOST=tcps://example.swim.faa.gov:55443
SWIM_VPN=TFMS
SWIM_USER=
SWIM_PASS=
SWIM_QUEUE=
# Optional: 0-9, higher = more CPU / less bandwidth. Default matches the spike.
SWIM_COMPRESSION=9
# Note: the SWIFT portal also issues SWIM_CONNECTION_FACTORY, but that's a JMS/JNDI artifact —
# the native solace-pubsubplus client used here connects by host/vpn/queue only, so it's unused.
